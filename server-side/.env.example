# Database
DATABASE_URL="postgresql://username:password@localhost:5432/qcexclusive"

# JWT Tokens
JWT_ACCESS_TOKEN="your-super-secret-jwt-access-token"
JWT_ACCESS_EXPIRES="7d"
JWT_REFRESH_TOKEN="your-super-secret-jwt-refresh-token"
JWT_REFRESH_EXPIRES="30d"

# Resend Email Service
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM="QC Exclusive <your-email@yourdomain.com>"

# Gmail IMAP (for inbox sync)
SMTP_HOST="imap.gmail.com"
SMTP_PORT=993
SMTP_USER="your-gmail-address@gmail.com"
SMTP_PASS="your-gmail-app-password"
SMTP_FROM="your-gmail-address@gmail.com"

# OpenAI API (for AI classification and reply generation)
OPENAI_API_KEY="sk-your-openai-api-key"

# Redis
RedisHost="localhost"
RedisPort=6379
RedisUserName=""
RedisPassword="your-redis-password"

# Frontend
FRONTEND_URL="http://localhost:3000"

# APIfy (for web scraping)
APIFY_TOKEN="your-apify-token"

# Server
PORT=5000
NODE_ENV="development"

# External API URLs
CALENDLY_API_BASE_URL="https://api.calendly.com"
APIFY_API_BASE_URL="https://api.apify.com"
N8N_WEBHOOK_URL="https://qcexclusive.app.n8n.cloud/webhook/doc"

# Meeting Configuration
DEFAULT_MEETING_LINK="https://meet.google.com/qcx-clusive"

# Development URLs
DEV_FRONTEND_URL="http://localhost:3000"
DEV_VITE_URL="http://localhost:5173"
PRODUCTION_FRONTEND_URL="https://qcexclusive-full-stack.vercel.app"
