<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Your OTP Code – QC-EXCLUSIVE</title>
</head>

<body style="margin:0;padding:0;background-color:#0a0a0a;font-family:'Segoe UI',Arial,sans-serif;">

    <!-- Wrapper -->
    <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#0a0a0a;padding:40px 20px;">
        <tr>
            <td align="center">

                <!-- Card -->
                <table width="100%"
                    style="max-width:560px;background:linear-gradient(145deg,#111111,#1a1a1a);border-radius:16px;border:1px solid #2a2a2a;overflow:hidden;">

                    <!-- Header -->
                    <tr>
                        <td
                            style="background:linear-gradient(135deg,#1a1a1a 0%,#0f0f0f 100%);padding:36px 40px 28px;text-align:center;border-bottom:1px solid #2a2a2a;">
                            <!-- Logo Text -->
                            <div
                                style="font-size:11px;letter-spacing:6px;color:#b8962e;font-weight:700;text-transform:uppercase;margin-bottom:8px;">
                                ✦ SINCE 2024 ✦</div>
                            <div
                                style="font-size:28px;font-weight:800;letter-spacing:4px;color:#ffffff;text-transform:uppercase;">
                                QC<span style="color:#c9a84c;">-</span>EXCLUSIVE</div>
                            <div
                                style="width:60px;height:2px;background:linear-gradient(90deg,transparent,#c9a84c,transparent);margin:14px auto 0;">
                            </div>
                        </td>
                    </tr>

                    <!-- Body -->
                    <tr>
                        <td style="padding:40px 40px 20px;">

                            <!-- Greeting -->
                            <p
                                style="margin:0 0 6px;font-size:13px;color:#888;letter-spacing:1px;text-transform:uppercase;">
                                Hello,</p>
                            <h2 style="margin:0 0 20px;font-size:22px;color:#ffffff;font-weight:600;">
                                <%= name %>
                            </h2>

                            <!-- Info text -->
                            <p style="margin:0 0 30px;font-size:15px;line-height:1.7;color:#aaa;">
                                We received a request to reset your password. Use the one-time verification code below.
                                This code is valid for <strong style="color:#c9a84c;">2 minutes</strong>.
                            </p>

                            <!-- OTP Box -->
                            <div
                                style="background:linear-gradient(135deg,#0f0f0f,#161616);border:1px solid #2e2e2e;border-radius:12px;padding:30px 20px;text-align:center;margin-bottom:30px;">
                                <p
                                    style="margin:0 0 16px;font-size:11px;letter-spacing:3px;color:#666;text-transform:uppercase;">
                                    Your Verification Code</p>

                                <!-- OTP Digits -->
                                <div style="display:inline-block;">
                                    <% var digits=otp.toString().split(''); %>
                                        <% digits.forEach(function(digit) { %>
                                            <span
                                                style="display:inline-block;width:44px;height:54px;line-height:54px;background:linear-gradient(145deg,#1e1e1e,#161616);border:1px solid #c9a84c33;border-radius:8px;font-size:28px;font-weight:700;color:#c9a84c;text-align:center;margin:0 4px;letter-spacing:0;font-family:'Courier New',monospace;">
                                                <%= digit %>
                                            </span>
                                            <% }); %>
                                </div>

                                <p style="margin:18px 0 0;font-size:12px;color:#555;">Do not share this code with
                                    anyone.</p>
                            </div>

                            <!-- Warning Box -->
                            <table width="100%" cellpadding="0" cellspacing="0"
                                style="background:#1a1208;border:1px solid #3d2e0a;border-radius:10px;margin-bottom:30px;">
                                <tr>
                                    <td style="padding:14px 18px;">
                                        <p style="margin:0;font-size:13px;color:#c9a84c;line-height:1.6;">
                                            ⚠️ If you did not request a password reset, please ignore this email or
                                            contact our support team immediately.
                                        </p>
                                    </td>
                                </tr>
                            </table>

                        </td>
                    </tr>

                    <!-- Divider -->
                    <tr>
                        <td style="padding:0 40px;">
                            <div style="height:1px;background:linear-gradient(90deg,transparent,#2a2a2a,transparent);">
                            </div>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td style="padding:24px 40px 36px;text-align:center;">
                            <p style="margin:0 0 8px;font-size:12px;color:#555;line-height:1.6;">
                                This is an automated message from <strong
                                    style="color:#888;">QC-EXCLUSIVE</strong>.<br />
                                Please do not reply to this email.
                            </p>
                            <p
                                style="margin:12px 0 0;font-size:11px;letter-spacing:2px;color:#333;text-transform:uppercase;">
                                © 2024 QC-EXCLUSIVE. All Rights Reserved.</p>
                        </td>
                    </tr>

                </table>
                <!-- End Card -->

            </td>
        </tr>
    </table>

</body>

</html>